															<Value>=FormatNumber(Fields!LuongCoBan.Value,0) &amp; " VND  |  Phụ cấp: " &amp; FormatNumber(Fields!PhuCap.Value,0) &amp; " VND"</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
											<Style>
												<Border>
													<Color>LightGrey</Color>
													<Style>Solid</Style>
													<Width>0.25pt</Width>
												</Border>
												<PaddingLeft>4pt</PaddingLeft>
												<PaddingRight>2pt</PaddingRight>
												<PaddingTop>2pt</PaddingTop>
												<PaddingBottom>2pt</PaddingBottom>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
							</TablixCells>
						</TablixRow>

						<!-- Trạng thái làm việc -->
						<TablixRow>

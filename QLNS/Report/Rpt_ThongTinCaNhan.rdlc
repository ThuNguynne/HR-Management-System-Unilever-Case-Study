<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition"
        xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
	<AutoRefresh>0</AutoRefresh>

	<!-- DATA SOURCE -->
	<DataSources>
		<DataSource Name="UnileverHRMDataSet">
			<ConnectionProperties>
				<DataProvider>System.Data.DataSet</DataProvider>
				<ConnectString>/* Local Connection */</ConnectString>
			</ConnectionProperties>
			<rd:DataSourceID>11111111-1111-1111-1111-111111111111</rd:DataSourceID>
		</DataSource>
	</DataSources>

	<!-- DATASET TỪ vw_ThongTinNhanVien -->
	<DataSets>
		<DataSet Name="DataSet1">
			<Fields>
				<Field Name="MaNV">
					<DataField>MaNV</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="HoTen">
					<DataField>HoTen</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="NgaySinh">
					<DataField>NgaySinh</DataField>
					<rd:TypeName>System.DateTime</rd:TypeName>
				</Field>
				<Field Name="Tuoi">
					<DataField>Tuoi</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="GioiTinh">
					<DataField>GioiTinh</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="DienThoai">
					<DataField>DienThoai</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="Email">
					<DataField>Email</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="PhongBan">
					<DataField>PhongBan</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="ChucVu">
					<DataField>ChucVu</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
				<Field Name="CapBac">
					<DataField>CapBac</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="NgayVaoLam">
					<DataField>NgayVaoLam</DataField>
					<rd:TypeName>System.DateTime</rd:TypeName>
				</Field>
				<Field Name="ThangLamViec">
					<DataField>ThangLamViec</DataField>
					<rd:TypeName>System.Int32</rd:TypeName>
				</Field>
				<Field Name="LuongCoBan">
					<DataField>LuongCoBan</DataField>
					<rd:TypeName>System.Decimal</rd:TypeName>
				</Field>
				<Field Name="PhuCap">
					<DataField>PhuCap</DataField>
					<rd:TypeName>System.Decimal</rd:TypeName>
				</Field>
				<Field Name="TrangThai">
					<DataField>TrangThai</DataField>
					<rd:TypeName>System.String</rd:TypeName>
				</Field>
			</Fields>
			<Query>
				<DataSourceName>UnileverHRMDataSet</DataSourceName>
				<CommandText>/* Local Query: Data đã được truyền từ code */</CommandText>
			</Query>
		</DataSet>
	</DataSets>

	<Body>
		<ReportItems>

			<!-- TIÊU ĐỀ -->
			<Textbox Name="ReportTitle">
				<CanGrow>true</CanGrow>
				<KeepTogether>true</KeepTogether>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>=Parameters!pTieuDe.Value</Value>
								<Style>
									<FontFamily>Segoe UI</FontFamily>
									<FontSize>16pt</FontSize>
									<FontWeight>Bold</FontWeight>
									<Color>#0047ba</Color>
								</Style>
							</TextRun>
						</TextRuns>
						<Style>
							<TextAlign>Center</TextAlign>
						</Style>
					</Paragraph>
				</Paragraphs>
				<Top>0in</Top>
				<Left>0in</Left>
				<Height>0.4in</Height>
				<Width>8in</Width>
				<Style>
					<Border>
						<Style>None</Style>
					</Border>
					<PaddingLeft>2pt</PaddingLeft>
					<PaddingRight>2pt</PaddingRight>
					<PaddingTop>2pt</PaddingTop>
					<PaddingBottom>2pt</PaddingBottom>
				</Style>
			</Textbox>

			<!-- BẢNG THÔNG TIN CÁ NHÂN (2 CỘT: NHÃN + GIÁ TRỊ) -->

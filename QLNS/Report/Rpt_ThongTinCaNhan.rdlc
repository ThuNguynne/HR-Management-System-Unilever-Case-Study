																<FontWeight>Bold</FontWeight>
															</Style>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
											<Style>
												<Border>
													<Color>LightGrey</Color>
													<Style>Solid</Style>
													<Width>0.25pt</Width>
												</Border>
												<BackgroundColor>#f0f4f8</BackgroundColor>
												<PaddingLeft>4pt</PaddingLeft>
												<PaddingRight>2pt</PaddingRight>
												<PaddingTop>2pt</PaddingTop>
												<PaddingBottom>2pt</PaddingBottom>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
								<TablixCell>
									<CellContents>
										<Textbox Name="ValMaNV">
											<CanGrow>true</CanGrow>
											<KeepTogether>true</KeepTogether>
											<Paragraphs>
												<Paragraph>
													<TextRuns>
														<TextRun>
															<Value>=Fields!MaNV.Value</Value>
														</TextRun>
													</TextRuns>
												</Paragraph>
											</Paragraphs>
											<Style>
												<Border>
													<Color>LightGrey</Color>
													<Style>Solid</Style>
													<Width>0.25pt</Width>
												</Border>
												<PaddingLeft>4pt</PaddingLeft>
												<PaddingRight>2pt</PaddingRight>
												<PaddingTop>2pt</PaddingTop>
												<PaddingBottom>2pt</PaddingBottom>
											</Style>
										</Textbox>
									</CellContents>
								</TablixCell>
							</TablixCells>
						</TablixRow>

